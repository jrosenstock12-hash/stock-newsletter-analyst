{
  "folders": [
    {
      "path": "."
    }
  ],
  "settings": {
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.terminal.activateEnvironment": true,
    "files.exclude": {
      "**/__pycache__": true,
      ".venv": false
    }
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Start app",
        "type": "shell",
        "command": "./scripts/start.sh",
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "presentation": {
          "reveal": "always",
          "panel": "dedicated"
        }
      },
      {
        "label": "Test OpenAI",
        "type": "shell",
        "command": "./scripts/test-api.sh"
      },
      {
        "label": "Analyze sample",
        "type": "shell",
        "command": "./scripts/analyze-sample.sh"
      }
    ]
  }
}
